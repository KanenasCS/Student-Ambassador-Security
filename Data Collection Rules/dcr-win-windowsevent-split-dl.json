{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "author": "GV",
        "date": "28/04/2026",
        "description": "Create a custom Auxiliary/Data Lake table and split specific Windows Event IDs to it by deploying a DCR for Microsoft-WindowsEvent with 2 different output streams. Reserved Log Analytics columns are excluded and WindowsEvents dynamic columns are stored as strings because Auxiliary tables do not support dynamic columns; the custom output flow casts those fields to string."
    },
    "parameters": {
        "subscriptionId": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Specify the Subscription Id of the Microsoft Sentinel workspace"
            }
        },
        "resourceGroup": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Specify the Resource Group of the Microsoft Sentinel workspace"
            }
        },
        "workspaceName": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Specify the name of the Microsoft Sentinel Log Analytics workspace"
            }
        },
        "tableName": {
            "defaultValue": "Windows_WindowsEvents_CL",
            "type": "string",
            "metadata": {
                "description": "Specify the name of the custom Data Lake table to create. Uses the WindowsEvent schema, excluding reserved Log Analytics columns; Data and EventData are stored as string for Auxiliary compatibility."
            }
        },
        "dataRetentionInDays": {
            "defaultValue": 365,
            "type": "int",
            "metadata": {
                "description": "Specify the total data retention in days for the custom Data Lake table. The default value is 365 days."
            }
        }
    },
    "variables": {
        "streamName": "[concat('Custom-', parameters('tableName'))]",
        "workspaceResourceId": "[resourceId(parameters('subscriptionId'), parameters('resourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]"
    },
    "resources": [
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2025-07-01",
            "name": "[concat(parameters('workspaceName'), '/', parameters('tableName'))]",
            "properties": {
                "totalRetentionInDays": "[parameters('dataRetentionInDays')]",
                "plan": "Auxiliary",
                "schema": {
                    "name": "[parameters('tableName')]",
                    "columns": [
                        {
                            "name": "SourceSystem",
                            "type": "string"
                        },
                        {
                            "name": "TimeGenerated",
                            "type": "datetime"
                        },
                        {
                            "name": "Provider",
                            "type": "string"
                        },
                        {
                            "name": "Channel",
                            "type": "string"
                        },
                        {
                            "name": "Computer",
                            "type": "string"
                        },
                        {
                            "name": "Task",
                            "type": "int"
                        },
                        {
                            "name": "EventLevel",
                            "type": "int"
                        },
                        {
                            "name": "EventLevelName",
                            "type": "string"
                        },
                        {
                            "name": "Data",
                            "type": "string"
                        },
                        {
                            "name": "EventID",
                            "type": "int"
                        },
                        {
                            "name": "ManagementGroupName",
                            "type": "string"
                        },
                        {
                            "name": "SystemUserId",
                            "type": "string"
                        },
                        {
                            "name": "Version",
                            "type": "int"
                        },
                        {
                            "name": "Opcode",
                            "type": "string"
                        },
                        {
                            "name": "Keywords",
                            "type": "string"
                        },
                        {
                            "name": "Correlation",
                            "type": "string"
                        },
                        {
                            "name": "SystemProcessId",
                            "type": "int"
                        },
                        {
                            "name": "SystemThreadId",
                            "type": "int"
                        },
                        {
                            "name": "EventRecordId",
                            "type": "string"
                        },
                        {
                            "name": "EventData",
                            "type": "string"
                        },
                        {
                            "name": "RawEventData",
                            "type": "string"
                        },
                        {
                            "name": "EventOriginId",
                            "type": "string"
                        },
                        {
                            "name": "TimeCreated",
                            "type": "datetime"
                        }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionRules",
            "apiVersion": "2024-03-11",
            "name": "dcr-win-windowsevents-split-dl",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('workspaceName'), parameters('tableName'))]"
            ],
            "kind": "Windows",
            "properties": {
                "description": "Data Collection Rule for splitting specific Windows Event IDs to a Data Lake table, while routing all remaining Windows Events to the standard Microsoft-WindowsEvent stream.",
                "dataSources": {
                    "windowsEventLogs": [
                        {
                            "streams": [
                                "Microsoft-WindowsEvent"
                            ],
                            "xPathQueries": [
                                "ForwardedEvents!*"
                            ],
                            "name": "WindowsEvents-DataSource"
                        }
                    ]
                },
                "destinations": {
                    "logAnalytics": [
                        {
                            "workspaceResourceId": "[variables('workspaceResourceId')]",
                            "name": "MicrosoftSentinel"
                        }
                    ]
                },
                "dataFlows": [
                    {
                        "streams": [
                            "Microsoft-WindowsEvent"
                        ],
                        "destinations": [
                            "MicrosoftSentinel"
                        ],
                        "transformKql": "source | where EventID != 4634",
                        "outputStream": "Microsoft-WindowsEvent"
                    },
                    {
                        "streams": [
                            "Microsoft-WindowsEvent"
                        ],
                        "destinations": [
                            "MicrosoftSentinel"
                        ],
                        "transformKql": "source | where EventID == 4634 | extend Data = tostring(Data), EventData = tostring(EventData)",
                        "outputStream": "[variables('streamName')]"
                    }
                ]
            }
        }
    ],
    "outputs": {
        "customTableName": {
            "type": "string",
            "value": "[parameters('tableName')]"
        },
        "dcrResourceId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Insights/dataCollectionRules', 'dcr-win-windowsevents-split-dl')]"
        }
    }
}
