                    ]
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionRules",
            "apiVersion": "2024-03-11",
            "name": "dcr-win-security-split-dl",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('workspaceName'), parameters('tableName'))]"
            ],
            "kind": "Windows",
            "properties": {
                "description": "Data Collection Rule for splitting specific Windows Security Event IDs to a Data Lake table, while routing all remaining Security Events to the standard Microsoft-SecurityEvent stream.",
                "dataSources": {
                    "windowsEventLogs": [
                        {
                            "streams": [
                                "Microsoft-SecurityEvent"
                            ],
                            "xPathQueries": [
                                "Security!*"
                            ],
                            "name": "SecurityEvent-DataSource"
                        }
                    ]
                },
                "destinations": {
                    "logAnalytics": [
                        {
                            "workspaceResourceId": "[variables('workspaceResourceId')]",
                            "name": "MicrosoftSentinel"
                        }
                    ]
                },
                "dataFlows": [
                    {
                        "streams": [
                            "Microsoft-SecurityEvent"
                        ],
                        "destinations": [
                            "MicrosoftSentinel"
                        ],
                        "transformKql": "source | where EventID != 4634",
                        "outputStream": "Microsoft-SecurityEvent"
                    },
                    {
                        "streams": [
                            "Microsoft-SecurityEvent"
                        ],
                        "destinations": [
                            "MicrosoftSentinel"
                        ],
                        "transformKql": "source | where EventID == 4634",
                        "outputStream": "[variables('streamName')]"
                    }
                ]
            }
        }
    ],
    "outputs": {
        "customTableName": {
            "type": "string",
            "value": "[parameters('tableName')]"
        },
        "dcrResourceId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Insights/dataCollectionRules', 'dcr-win-security-split-dl')]"
        }
    }
}
