      "name": "EventCount by Onboarded Resource Type"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "union StorageBlobLogs, StorageFileLogs, StorageQueueLogs, StorageTableLogs, ContainerRegistryLoginEvents, AZFWNetworkRule, MicrosoftAzureBastionAuditLogs, AKSAuditAdmin, AKSControlPlane, AzureDiagnostics, workspace('mss-uaen-sentinel-vgs-hub').AKSAuditAdmin\r\n| parse _ResourceId with \"/subscriptions/\" firewalSub \"/resourcegroups/\" firewallRG \"/providers/microsoft.network/azurefirewalls/\" firewallName\r\n| parse _ResourceId with \"/subscriptions/\" bastionSub \"/resourcegroups/\" bastionRG \"/providers/microsoft.network/bastionhosts/\" bastionName\r\n| parse _ResourceId with \"/subscriptions/\" appgwSub \"/resourcegroups/\" appgwRG \"/providers/microsoft.network/applicationgateways/\" appgwName\r\n| parse _ResourceId with \"/subscriptions/\" vnetgwSub \"/resourcegroups/\" vnetgwRG \"/providers/microsoft.network/virtualnetworkgateways/\" vnetgwName\r\n| parse _ResourceId with \"/subscriptions/\" aksSub \"/resourcegroups/\" aksRG \"/providers/microsoft.containerservice/managedclusters/\" aksName\r\n| extend FirewallName = strcat(firewallName, \" @ \" , firewallRG)\r\n| extend BastionName = strcat(bastionName, \" @ \" , bastionRG)\r\n| extend AppGwName = strcat(appgwName, \" @ \" , appgwRG)\r\n| extend VnetGwName = strcat(vnetgwName, \" @ \" , vnetgwRG)\r\n| extend AKSName = aksName\r\n| extend Resource = iff (Type == \"StorageBlobLogs\", AccountName, \r\n                    iff (Type == \"StorageFileLogs\", AccountName, \r\n                    iff (Type == \"StorageQueueLogs\", AccountName,\r\n                    iff (Type == \"StorageTableLogs\", AccountName, \r\n                    iff (Type == \"ContainerRegistryLoginEvents\", LoginServer,\r\n                    iff (Type == \"MicrosoftAzureBastionAuditLogs\", BastionName, \r\n                    iff (Type == \"AZFWNetworkRule\", FirewallName, \r\n                    iff (Type == \"AKSAuditAdmin\" or Type == \"AKSControlPlane\", AKSName,\r\n                    iff (ResourceType == \"APPLICATIONGATEWAYS\", AppGwName, \r\n                    iff (ResourceType == \"VIRTUALNETWORKGATEWAYS\", VnetGwName, \r\n                    iff (ResourceType == \"SERVERS/DATABASES\", LogicalServerName_s, Resource)))))))))))\r\n| extend ResourceType = iff (Type == \"StorageBlobLogs\", \"STORAGEACCOUNTS\", \r\n                    iff (Type == \"StorageFileLogs\", \"STORAGEACCOUNTS\", \r\n                    iff (Type == \"StorageQueueLogs\", \"STORAGEACCOUNTS\", \r\n                    iff (Type == \"StorageTableLogs\", \"STORAGEACCOUNTS\",\r\n                    iff (Type == \"ContainerRegistryLoginEvents\", \"CONTAINERREGISTRIES\",\r\n                    iff (Type == \"MicrosoftAzureBastionAuditLogs\", \"BASTIONS\", \r\n                    iff (Type == \"AKSAuditAdmin\" or Type == \"AKSControlPlane\", \"MANAGEDCLUSTERS\", \r\n                    iff (Type == \"AZFWNetworkRule\", \"AZUREFIREWALLS\", ResourceType))))))))\r\n| where ResourceType == \"{ResourceType}\"\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2) by Resource\r\n| order by EventCount",
        "size": 0,
        "showAnalytics": true,
        "title": "Overview of \"{ResourceType}\" resource type",
        "noDataMessage": "Select ResourceType",
        "noDataMessageStyle": 2,
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "EventCount",
              "formatter": 8,
              "formatOptions": {
                "palette": "blue"
              }
            }
          ],
          "filter": true,
          "sortBy": [
            {
              "itemKey": "Resource",
              "sortOrder": 1
            }
          ]
        },
        "sortBy": [
          {
            "itemKey": "Resource",
            "sortOrder": 1
          }
        ]
