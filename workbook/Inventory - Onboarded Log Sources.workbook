    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "union StorageBlobLogs, StorageFileLogs, StorageQueueLogs, StorageTableLogs, ContainerRegistryLoginEvents, AZFWNetworkRule, MicrosoftAzureBastionAuditLogs, AKSAuditAdmin, AzureDiagnostics, AKSControlPlane, workspace('mss-uaen-sentinel-vgs-hub').AKSAuditAdmin\r\n| extend Type = iff (ResourceType == \"VAULTS\", \"Azure Key Vault\",\r\n    iff (Type == \"StorageBlobLogs\", \"Storage Account\",\r\n    iff (Type == \"StorageFileLogs\", \"Storage Account\",\r\n    iff (Type == \"StorageQueueLogs\", \"Storage Account\",\r\n    iff (Type == \"StorageTableLogs\", \"Storage Account\", \r\n    iff (Type == \"ContainerRegistryLoginEvents\", \"Container Registry\",\r\n    iff (Type == \"AZFWNetworkRule\", \"Azure Firewall\",\r\n    iff (Type == \"MicrosoftAzureBastionAuditLogs\", \"Bastions\",\r\n    iff (Type == \"AKSAuditAdmin\" or Type == \"AKSControlPlane\", \"Azure Kubernetes Cluster\",\r\n    iff (ResourceType == \"MANAGEDCLUSTERS\", \"Azure Kubernetes Cluster\",\r\n    iff (ResourceType == \"NETWORKSECURITYGROUPS\", \"Network Security Group\",\r\n    iff (ResourceType == \"SERVERS/DATABASES\", \"Azure SQL Database\",\r\n    iff (ResourceType == \"VIRTUALNETWORKGATEWAYS\", \"Virtual Network Gateway\",\r\n    iff (ResourceType == \"EXPRESSROUTECIRCUITS\", \"ExpressRoute Circuit\",\r\n    iff (ResourceType == \"NAMESPACES\", \"Event Hub\",\r\n    iff (ResourceType == \"APPLICATIONGATEWAYS\" , \"Application Gateway\", \r\n    iff (ResourceType == \"DATABASEACCOUNTS\" , \"Azure CosmosDB\",\r\n    iff (ResourceType == \"MANAGEDINSTANCES\" , \"SQL Managed Instance\", \r\n    iff (ResourceType == \"SEARCHSERVICES\" , \"Azure GPT Services\", ResourceType)))))))))))))))))))\r\n| extend ResourceType = iff(Type == \"Storage Account\", \"STORAGEACCOUNTS\",\r\n                        iff(Type == \"Container Registry\", \"CONTAINERREGISTRIES\", \r\n                        iff(Type == \"Azure Kubernetes Cluster\", \"MANAGEDCLUSTERS\", \r\n                        iff(Type == \"Bastions\", \"BASTIONS\", \r\n                        iff(Type == \"Azure Firewall\", \"AZUREFIREWALLS\",\r\n                        iff(Type == \"SQL Managed Instance\", \"MANAGEDINSTANCES\",\r\n                        iff(Type == \"Azure Search\", \"SEARCHSERVICES\", ResourceType)))))))\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2) by ResourceType, Type\r\n| order by EventCount",
        "size": 0,
        "showAnalytics": true,
        "title": "EventCount by Onboarded Resource Type",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "exportFieldName": "ResourceType",
