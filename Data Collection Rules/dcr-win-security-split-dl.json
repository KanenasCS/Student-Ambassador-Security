{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "author": "GV",
        "date": "28/04/2026",
        "description": "Create a custom Data Lake table and split specific Windows Security Event IDs to it by deploying a DCR for Microsoft-SecurityEvent with 2 different output streams. The data retention in days is configurable before deployment."
    },
    "parameters": {
        "subscriptionId": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Specify the Subscription Id of the Microsoft Sentinel workspace"
            }
        },
        "resourceGroup": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Specify the Resource Group of the Microsoft Sentinel workspace"
            }
        },
        "workspaceName": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Specify the name of the Microsoft Sentinel Log Analytics workspace"
            }
        },
        "tableName": {
            "defaultValue": "Windows_SecurityEvent_CL",
            "type": "string",
            "metadata": {
                "description": "Specify the name of the custom Data Lake table to create. Must match the SecurityEvent schema."
            }
        },
        "dataRetentionInDays": {
            "defaultValue": 365,
            "type": "int",
            "metadata": {
                "description": "Specify the total data retention in days for the custom Data Lake table. The default value is 365 days."
            }
        }
    },
    "variables": {
        "streamName": "[concat('Custom-', parameters('tableName'))]",
        "workspaceResourceId": "[resourceId(parameters('subscriptionId'), parameters('resourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]"
    },
    "resources": [
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2025-07-01",
            "name": "[concat(parameters('workspaceName'), '/', parameters('tableName'))]",
            "properties": {
                "totalRetentionInDays": "[parameters('dataRetentionInDays')]",
                "plan": "Auxiliary",
                "schema": {
                    "name": "[parameters('tableName')]",
                    "columns": [
                        {"name":"TimeGenerated","type":"datetime"},
                        {"name":"TimeCollected","type":"datetime"},
                        {"name":"AccessList","type":"string"},
                        {"name":"AccessMask","type":"string"},
