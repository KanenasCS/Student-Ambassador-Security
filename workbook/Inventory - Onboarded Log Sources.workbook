      "content": {
        "version": "KqlItem/1.0",
        "query": "union CloudAppEvents, EmailAttachmentInfo, EmailUrlInfo, EmailEvents, IdentityQueryEvents, IdentityLogonEvents, IdentityDirectoryEvents, UrlClickEvents, EmailPostDeliveryEvents, MicrosoftPurviewInformationProtection\r\n| extend Service = iff (Type startswith \"Email\", \"Defender for Office 365\",\r\n    iff (Type startswith \"Identity\", \"Defender for Identity\",\r\n    iff (Type startswith \"CloudAppEvents\", \"Defender for Cloud Apps\",\r\n    iff (Type == \"MicrosoftPurviewInformationProtection\", \"Microsoft Purview\", \"Defender for Office 365\"))))\r\n| summarize EventCount = count() by Type, Service\r\n| order by EventCount",
        "size": 0,
        "showAnalytics": true,
        "title": "Overview of Telemetry Data per Service",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "EventCount",
              "formatter": 8,
              "formatOptions": {
                "palette": "blue"
              }
            }
          ],
          "filter": true
        },
        "sortBy": []
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "tenant"
      },
      "customWidth": "50",
      "name": "Overview of Telemetry Data per Service"
    },
