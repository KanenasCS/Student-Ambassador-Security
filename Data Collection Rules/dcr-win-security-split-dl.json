                        {"name":"Activity","type":"string"},
                        {"name":"AdditionalInfo","type":"string"},
                        {"name":"AdditionalInfo2","type":"string"},
                        {"name":"AllowedToDelegateTo","type":"string"},
                        {"name":"Attributes","type":"string"},
                        {"name":"AuditPolicyChanges","type":"string"},
