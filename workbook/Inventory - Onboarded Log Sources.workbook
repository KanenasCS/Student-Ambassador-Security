    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "union securityevent_raw,syslog_raw\r\n| where Computer !contains \"f5\" //Exclude DH's F5 Balancers\r\n| where Computer !=\"VMCAPVAULT001\" //Exclude DH's CyberArks\r\n| where Computer != \"vmnacentmgr01\" //Exclude DH's NAC\r\n| where ProcessName !contains \"netflowd\" and ProcessName !contains \"mgmtd\" //Exclude DH's Aruba SD-WAN\r\n| where Computer !contains \"F5\" //Exclude DPR's F5 Balancers\r\n| where Computer !contains \"rwdcpopss\" //Exclude DPR's Cisco ISE\r\n| where Computer !contains \"10.0.33.25\" //Exclude DPR's Balancer Spoofed Devices\r\n| where Computer !contains \"10.1.1.1\" //Exclude DPR's Cisco Router\r\n| where Computer !contains \"10.227.1.150\" //Exclude DPR's BeyondTrust\r\n| where Computer !contains \"rwdcise\" //Exclude DPR's Cisco ISE \r\n| where Computer !contains \"ise3\" //Exclude DPR's Cisco ISE \r\n| where Computer !contains \"10.30.100.80\" //Exclude DPR's Cisco ISE\r\n| extend Type = iff(Type == \"SecurityEvent\", \"Windows\", \"Linux\")\r\n| summarize OnboardedIaaS = dcount(Computer) by Subsidiary, Type",
        "size": 3,
        "showAnalytics": true,
        "title": "Onboarded VMs per Subsidiary and OS type",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "exportedParameters": [
          {
            "fieldName": "Subsidiary",
            "parameterName": "Subsidiary",
            "parameterType": 1
          },
          {
            "fieldName": "Type",
            "parameterName": "Type",
            "parameterType": 1
          }
        ],
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "visualization": "tiles",
        "tileSettings": {
          "titleContent": {
            "columnMatch": "OnboardedIaaS",
            "formatter": 12,
            "formatOptions": {
              "palette": "redGreen"
            }
          },
          "subtitleContent": {
            "columnMatch": "Subsidiary",
            "formatter": 1
          },
          "leftContent": {
            "columnMatch": "Type",
            "formatter": 1
          },
          "showBorder": true,
          "styleSettings": {
            "borderStyle": "rounded",
            "backgroundColor": "colorGray100"
          }
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "vm"
      },
      "customWidth": "50",
      "name": "Onboarded VMs per Subsidiary and OS type"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let SubscriptionMapping = _GetWatchlist('subscriptions');\r\nunion syslog_raw,securityevent_raw,event_raw\r\n| where Computer !contains \"f5\" //Exclude DH's F5 Balancers\r\n| where Computer !=\"VMCAPVAULT001\" //Exclude DH's CyberArks\r\n| where Computer != \"vmnacentmgr01\" //Exclude DH's NAC\r\n| where ProcessName !contains \"netflowd\" and ProcessName !contains \"mgmtd\" //Exclude DH's Aruba SD-WAN\r\n| where Computer !contains \"F5\" //Exclude DPR's F5 Balancers\r\n| where Computer !contains \"rwdcpopss\" //Exclude DPR's Cisco ISE\r\n| where Computer !contains \"10.0.33.25\" //Exclude DPR's Balancer Spoofed Devices\r\n| where Computer !contains \"10.1.1.1\" //Exclude DPR's Cisco Router\r\n| where Computer !contains \"10.227.1.150\" //Exclude DPR's BeyondTrust\r\n| where Computer !contains \"rwdcise\" //Exclude DPR's Cisco ISE \r\n| where Computer !contains \"ise3\" //Exclude DPR's Cisco ISE \r\n| where Computer !contains \"10.30.100.80\" //Exclude DPR's Cisco ISE\r\n| where Source != \"MSSQLSERVER\" //Exclude Microsoft SQL Logs\r\n//Exlusions due to parsing issues\r\n| extend SpliSub = split (_ResourceId, \"/\")\r\n| extend Sub = tostring(SpliSub[2])\r\n| lookup kind=leftouter (SubscriptionMapping) on $left.Sub == $right.SearchKey\r\n| extend Type = iff(SourceSystem == \"Linux\", \"Linux\", \r\n                iff(Channel == \"Security\", \"Windows\",\r\n                iff(EventLog == \"Application\", \"Windows\", \"Windows\")))\r\n| extend Subtype = iff(SourceSystem == \"Linux\", \"Linux\", \r\n                iff(Channel == \"Security\", \"Security\",\r\n                iff(EventLog == \"Application\", \"Application\", \"System\")))\r\n| extend Subscription = Name\r\n| where Subsidiary == \"{Subsidiary}\" and Type == \"{Type}\"\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2)  by Computer, Subsidiary, Type, Subtype, Subscription, ManagementGroup\r\n| order by EventCount",
        "size": 0,
        "showAnalytics": true,
        "title": "{Type} VMs at {Subsidiary} ",
        "noDataMessage": "Select Type and Subsidiary",
        "noDataMessageStyle": 2,
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "EventCount",
              "formatter": 8,
              "formatOptions": {
                "palette": "blue"
              }
            }
          ],
          "rowLimit": 10000,
          "filter": true
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "vm"
      },
      "customWidth": "50",
      "name": "{Type} VMs at {Subsidiary} "
    },
