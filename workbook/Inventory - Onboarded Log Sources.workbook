    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let SyslogTable = Syslog \r\n| where Computer == \"vmnacentmgr0\" or Computer contains \"F5-DPR\" or Computer contains \"10.1.1.1\" or Computer contains \"10.227.1.15\";\r\nlet SDWANTable = Syslog\r\n| where ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\";\r\nunion SyslogTable, SDWANTable, ForescoutEvent, CommonSecurityLog, CiscoISEEvent\r\n| extend Computer = iff (Computer == \"localhost\", FlexString1,\r\n                    iff (isnotempty(EventHostName), EventHostName, Computer))\r\n| distinct Computer\r\n| count",
        "size": 4,
        "showAnalytics": true,
        "title": "Count of Onboarded Network Security Devices",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "visualization": "tiles",
        "tileSettings": {
          "titleContent": {
            "columnMatch": "Count",
            "formatter": 12,
            "formatOptions": {
              "palette": "redGreen",
              "compositeBarSettings": {
                "labelText": "",
                "columnSettings": []
              }
            },
            "numberFormat": {
              "unit": 0,
              "options": {
                "style": "decimal"
              }
            }
          },
          "showBorder": false,
          "size": "auto"
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "security"
      },
      "customWidth": "50",
      "name": "Count of Onboarded Network Security Devices"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let SyslogTable = Syslog \r\n| where Computer == \"vmnacentmgr0\" or Computer contains \"F5-DPR\" or Computer contains \"10.1.1.1\" or Computer contains \"10.227.1.15\";\r\nlet SDWANTable = Syslog\r\n| where ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\";\r\nunion SyslogTable, SDWANTable, ForescoutEvent, CommonSecurityLog, CiscoISEEvent\r\n| extend Info = iff (Computer contains \"dhf5cloud\", \"DH - Azure Old Landing Zone\",\r\n    iff (CollectorHostName contains \"RWPRDSENTAPP\", \"DPR - OnPrem\", \r\n    iff (EventHostName contains \"rwdcpopss\", \"DPR - OnPrem\", \r\n    iff (DeviceVendor contains \"Akamai\", \"DPR - Vendor Cloud\", \"DH - Azure New Landing Zone\"))))\r\n| extend Type = iff (DeviceVendor == \"Palo Alto Networks\", \"Firewall\",\r\n    iff (DeviceProduct == \"ASM\", \"WAF\",\r\n    iff (DeviceVendor == \"Fortinet\", \"Firewall\",\r\n    iff (EventVendor == \"Forescout\", \"NAC\",\r\n    iff (DeviceProduct == \"ASA\", \"Firewall\", \r\n    iff (EventProduct == \"ISE\", \"NAC\", \r\n    iff (DeviceVendor == \"Akamai\", \"CDN\", \r\n    iff (DeviceProduct == \"BeyondInsight\", \"PAM\",\r\n    iff (DeviceProduct == \"Vault\", \"Secrets Vault\",\r\n    iff (DeviceProduct == \"FortiGate-1500D\", \"Firewall\",\r\n    iff (Computer == \"zscaler-nss\", \"Web Proxy\",\r\n    iff (Computer == \"zscaler-nss-fw\", \"Firewall\",\r\n    iff (Computer contains \"F5-DPR\", \"Load Balancer\", \r\n    iff (Computer contains \"10.1.1.1\", \"Router\",\r\n    iff (Computer contains \"10.0.50.3\", \"Firewall\",\r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"SD-WAN\", \" \"))))))))))))))))\r\n| extend DeviceVendor = iff (Type == \"Syslog\", EventVendor, \r\n    iff (EventVendor == \"Forescout\", \"Forescout\", \r\n    iff (Computer contains\"F5-DPR\", \"F5\",\r\n    iff (EventProduct == \"ISE\", \"Cisco\", \r\n    iff (Computer contains \"10.1.1.1\", \"Router\",\r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"Aruba\", DeviceVendor))))))\r\n| extend Computer = iff (Computer == \"localhost\", FlexString1,\r\n    iff (isnotempty(EventHostName), EventHostName, Computer))\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2) by DeviceVendor, Computer, Type, Info\r\n| order by EventCount",
        "size": 0,
        "showAnalytics": true,
        "title": "Onboarded Security & Network Devices",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "EventCount",
              "formatter": 8,
              "formatOptions": {
                "palette": "blue"
              }
            }
          ],
          "rowLimit": 5000,
          "filter": true,
          "sortBy": [
            {
              "itemKey": "Type",
              "sortOrder": 1
            }
          ]
        },
        "sortBy": [
          {
            "itemKey": "Type",
            "sortOrder": 1
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "security"
      },
      "customWidth": "50",
      "name": "Onboarded Security & Network Devices"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let SyslogTable = Syslog \r\n| where Computer == \"vmnacentmgr0\" or Computer contains \"F5-DPR\" or Computer contains \"10.1.1.1\" or Computer contains \"10.227.1.15\";\r\nlet SDWANTable = Syslog\r\n| where ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\";\r\nunion SyslogTable, SDWANTable, ForescoutEvent, CommonSecurityLog, CiscoISEEvent\r\n| extend DeviceVendor = iff (Computer contains \"10.1.1.1\", \"Cisco\", \r\n    iff (EventVendor == \"Forescout\", \"Forescout\", \r\n    iff (Computer contains\"F5-DPR\", \"F5\",\r\n    iff (EventProduct == \"ISE\", \"Cisco\", \r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"Aruba\",\r\n    iff (Type == \"Syslog\", EventVendor, DeviceVendor))))))\r\n| extend DeviceProduct = iff (Computer contains \"10.1.1.1\", \"IOS\",\r\n    iff (Computer contains \"F5-DPR\", \"LTM\", \r\n    iff (DeviceProduct == \"akamai_siem\", \"Security Center\",\r\n    iff (EventProduct == \"ISE\", EventProduct,\r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"SD-WAN\",\r\n    iff (Type == \"Syslog\", EventProduct,  DeviceProduct))))))\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2) by DeviceVendor, DeviceProduct\r\n| order by EventCount\r\n",
        "size": 0,
        "showAnalytics": true,
        "title": "Device count per Vendor/Product",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "exportedParameters": [
          {
            "fieldName": "DeviceVendor",
            "parameterName": "DeviceVendor"
          },
          {
            "fieldName": "DeviceProduct",
            "parameterName": "DeviceProduct",
            "parameterType": 1,
            "defaultValue": ""
          }
        ],
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "EventCount",
              "formatter": 8,
              "formatOptions": {
                "palette": "blue"
              }
            }
          ],
          "rowLimit": 5000,
          "filter": true,
          "sortBy": [
            {
              "itemKey": "DeviceVendor",
              "sortOrder": 1
            }
          ]
        },
        "sortBy": [
          {
            "itemKey": "DeviceVendor",
            "sortOrder": 1
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "security"
      },
      "customWidth": "50",
      "name": "Device count per Vendor/Product"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let SyslogTable = Syslog \r\n| where Computer == \"vmnacentmgr0\" or Computer contains \"F5-DPR\" or Computer contains \"10.1.1.1\" or Computer contains \"10.227.1.15\";\r\nlet SDWANTable = Syslog\r\n| where ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\";\r\nunion SyslogTable, SDWANTable, ForescoutEvent, CommonSecurityLog, CiscoISEEvent\r\n| extend DeviceVendor = iff (Computer contains \"10.1.1.1\", \"Cisco\", \r\n    iff (EventVendor == \"Forescout\", \"Forescout\", \r\n    iff (Computer contains\"F5-DPR\", \"F5\",\r\n    iff (EventProduct == \"ISE\", \"Cisco\", \r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"Aruba\", \r\n    iff (Type == \"Syslog\", EventVendor, DeviceVendor))))))\r\n| extend DeviceProduct = iff (Computer contains \"10.1.1.1\", \"IOS\",\r\n    iff (Computer contains \"F5-DPR\", \"LTM\", \r\n    iff (DeviceProduct == \"akamai_siem\", \"Security Center\",\r\n    iff (EventProduct == \"ISE\", EventProduct, \r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"SD-WAN\",\r\n    iff (Type == \"Syslog\", EventProduct, DeviceProduct))))))\r\n| where DeviceVendor == \"{DeviceVendor}\" and DeviceProduct == \"{DeviceProduct}\"\r\n| extend HostName = iff(DeviceVendor == \"Cyber-Ark\", Computer,\r\n    iff(DeviceVendor == \"Forescout\", Computer, \r\n    iff(DeviceVendor == \"BeyondTrust\", Computer,\r\n    iff(EventProduct == \"ISE\", EventHostName,\r\n    iff(DeviceProduct == \"IOS\", Computer, \r\n    iff(DeviceVendor == \"Akamai\", \"Cloud API\", \r\n    iff(DeviceProduct == \"SD-WAN\", Computer, DeviceName)))))))\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2) by HostName, DeviceAddress",
        "size": 0,
        "showAnalytics": true,
        "title": "Device Overview for {DeviceVendor} {DeviceProduct}",
        "noDataMessage": "Select DeviceVendor / DeviceProduct",
        "noDataMessageStyle": 2,
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "EventCount",
              "formatter": 8,
              "formatOptions": {
                "palette": "blue"
              }
            }
          ],
          "filter": true
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "security"
      },
      "customWidth": "50",
      "name": "Device Overview for {DeviceVendor} {DeviceProduct}"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let SyslogTable = Syslog \r\n| where Computer == \"vmnacentmgr0\" or Computer contains \"F5-DPR\" or Computer contains \"10.1.1.1\" or Computer contains \"10.227.1.15\";\r\nlet SDWANTable = Syslog\r\n| where ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\";\r\nunion SyslogTable, SDWANTable, ForescoutEvent, CommonSecurityLog, CiscoISEEvent\r\n| extend DeviceVendor = iff (Computer contains \"10.1.1.1\", \"Cisco\", \r\n    iff (EventVendor == \"Forescout\", \"Forescout\", \r\n    iff (Computer contains\"F5-DPR\", \"F5\",\r\n    iff (EventProduct == \"ISE\", \"Cisco\", \r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"Aruba\",  \r\n    iff (Type == \"Syslog\", EventVendor, DeviceVendor))))))\r\n| extend DeviceProduct = iff (Computer contains \"10.1.1.1\", \"IOS\",\r\n    iff (Computer contains \"F5-DPR\", \"LTM\", \r\n    iff (DeviceProduct == \"akamai_siem\", \"Security Center\",\r\n    iff (EventProduct == \"ISE\", EventProduct, \r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", \"SD-WAN\", \r\n    iff (Type == \"Syslog\", EventProduct, DeviceProduct))))))\r\n| where DeviceVendor == \"{DeviceVendor}\" and DeviceProduct == \"{DeviceProduct}\"\r\n| extend EventName = iff(DeviceProduct == \"ASA\", DeviceAction,\r\n    iff (EventProduct == \"ISE\", EventMessage,\r\n    iff (Type == \"CommonSecurityLog\", Activity, \r\n    iff (ProcessName contains \"netflowd\" or ProcessName contains \"mgmtd\", ProcessName,  \r\n    iff (Type == \"Syslog\", EventName, \" \")))))\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2) by EventName\r\n| order by EventCount",
        "size": 0,
        "showAnalytics": true,
        "title": "Events Analysis for {DeviceVendor} {DeviceProduct}",
        "noDataMessage": "Select DeviceVendor / DeviceProduct",
        "noDataMessageStyle": 2,
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "EventCount",
              "formatter": 8,
              "formatOptions": {
                "palette": "blue"
              }
            }
          ],
          "filter": true
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "security"
      },
      "customWidth": "50",
      "name": "Events Analysis for {DeviceVendor} {DeviceProduct}"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "union StorageBlobLogs, StorageFileLogs, StorageQueueLogs, StorageTableLogs, ContainerRegistryLoginEvents, AZFWNetworkRule, AKSAuditAdmin, AzureDiagnostics\r\n| parse _ResourceId with \"/subscriptions/\" subId \"/resourcegroups/\" rgName \"/providers/microsoft.network/azurefirewalls/\" rName\r\n| parse _ResourceId with \"/subscriptions/\" aksSub \"/resourcegroups/\" aksRG \"/providers/microsoft.containerservice/managedclusters/\" aksName\r\n| extend FirewallName = strcat(rName, \" @ \" , rgName)\r\n| extend AKSName = aksName\r\n| extend Resource = iff (Type == \"StorageBlobLogs\", AccountName, \r\n                    iff (Type == \"StorageFileLogs\", AccountName, \r\n                    iff (Type == \"StorageQueueLogs\", AccountName, \r\n                    iff (Type == \"StorageTableLogs\", AccountName, \r\n                    iff (Type == \"AZFWNetworkRule\", FirewallName,\r\n                    iff (Category == \"ContainerRegistryLoginEvents\", LoginServer,\r\n                    iff (Type == \"AKSAuditAdmin\", AKSName,\r\n                    iff (Category == \"SQLSecurityAuditEvents\", LogicalServerName_s, Resource))))))))\r\n| distinct Resource\r\n| count",
        "size": 4,
        "showAnalytics": true,
        "title": "Count of Onboarded Azure PaaS Resources",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "visualization": "tiles",
        "tileSettings": {
          "titleContent": {
            "columnMatch": "Count",
            "formatter": 12,
            "formatOptions": {
              "palette": "redGreen"
            }
          },
          "showBorder": false
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "paas"
      },
      "customWidth": "50",
      "name": "Count of Onboarded Azure PaaS Resources"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "union StorageBlobLogs, StorageFileLogs, StorageQueueLogs, StorageTableLogs, ContainerRegistryLoginEvents, AZFWNetworkRule, MicrosoftAzureBastionAuditLogs, AKSAuditAdmin, AzureDiagnostics\r\n| extend ResourceType = iff (Type == \"StorageBlobLogs\", \"STORAGEACCOUNTS\", \r\n                    iff (Type == \"StorageFileLogs\", \"STORAGEACCOUNTS\", \r\n                    iff (Type == \"StorageQueueLogs\", \"STORAGEACCOUNTS\", \r\n                    iff (Type == \"StorageTableLogs\", \"STORAGEACCOUNTS\", \r\n                    iff (Type == \"ContainerRegistryLoginEvents\", \"CONTAINERREGISTRIES\",\r\n                    iff (Type == \"MicrosoftAzureBastionAuditLogs\", \"BASTIONS\",\r\n                    iff (Type == \"AKSAuditAdmin\", \"MANAGEDCLUSTERS\",\r\n                    iff (Type == \"AZFWNetworkRule\",\"AZUREFIREWALLS\", ResourceType))))))))\r\n| distinct ResourceType\r\n| count",
        "size": 4,
        "showAnalytics": true,
        "title": "Count of Onboarded Resource Types",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "visualization": "tiles",
        "tileSettings": {
          "titleContent": {
            "columnMatch": "Count",
            "formatter": 12,
            "formatOptions": {
              "palette": "redGreen"
            }
          },
          "showBorder": false
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "paas"
      },
      "customWidth": "50",
      "name": "Count of Onboarded Resource Types"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "workspace('mss-uaen-sentinel-hub').Informatica_CL\r\n| union workspace('mss-uaen-sentinel-hub').Palantir_CL, workspace('mss-uaen-sentinel-hub').Palantirv3_CL, workspace('mss-uaen-sentinel-hub01').AzureDevOpsAuditing, workspace('mss-uaen-sentinel-hub01').GitHubAuditLogsV2_CL, workspace('mss-uaen-sentinel-hub01').QualysHostDetectionV3_CL, workspace('mss-uaen-sentinel-hub').Auth0_CL,workspace('mss-uaen-sentinel-hub').EasmAsset_CL, workspace('mss-uaen-sentinel-hub').juniper_CL\r\n| extend Type = iff(Type == \"AzureDevOpsAuditing\", \"Azure DevOps\",\r\n                iff(Type == \"QualysHostDetectionV3_CL\", \"Qualys\",\r\n                iff(Type == \"Informatica_CL\", \"Informatica\",\r\n                iff(Type == \"Palantir_CL\", \"Palantir v2\",\r\n                iff(Type == \"Palantirv3_CL\", \"Palantir v3\",\r\n                iff(Type == \"EasmAsset_CL\", \"Defender EASM\",  \r\n                iff(Type == \"GitHubAuditLogsV2_CL\", \"GitHub Enterprise\",\r\n                iff(Type == \"Auth0_CL\", \"Auth0\", \r\n                iff(Type == \"juniper_CL\", \"Juniper Mist\", \"UNKNOWN\")))))))))\r\n| summarize OnboardedSaaS = dcount(ScopeDisplayName) by Type",
        "size": 3,
        "showAnalytics": true,
        "title": "Count of Onboarded SaaS Resources",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "crossComponentResources": [
          "/subscriptions/9e169f1f-abb5-4770-a511-5e7ad91caafb/resourceGroups/rg-mss-sentinel-001/providers/Microsoft.OperationalInsights/workspaces/mss-uaen-sentinel-hub",
          "/subscriptions/9e169f1f-abb5-4770-a511-5e7ad91caafb/resourceGroups/rg-mss-sentinel-001/providers/Microsoft.OperationalInsights/workspaces/mss-uaen-sentinel-hub01"
        ],
        "visualization": "tiles",
        "tileSettings": {
          "titleContent": {
            "columnMatch": "OnboardedSaaS",
            "formatter": 12,
            "formatOptions": {
              "palette": "redGreen"
            }
          },
          "secondaryContent": {
            "columnMatch": "Type",
            "formatter": 5
          },
          "showBorder": true,
          "size": "auto",
          "styleSettings": {
            "borderStyle": "rounded",
            "backgroundColor": "colorGray100"
          }
        }
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
