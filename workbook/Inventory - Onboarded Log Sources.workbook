    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "workspace('mss-uaen-sentinel-hub').Informatica_CL\r\n| union workspace('mss-uaen-sentinel-hub').Palantir_CL, workspace('mss-uaen-sentinel-hub').Palantirv3_CL, workspace('mss-uaen-sentinel-hub01').AzureDevOpsAuditing, workspace('mss-uaen-sentinel-hub01').GitHubAuditLogsV2_CL, workspace('mss-uaen-sentinel-hub01').QualysHostDetectionV3_CL, workspace('mss-uaen-sentinel-hub').Auth0_CL, workspace('mss-uaen-sentinel-hub').juniper_CL, workspace('mss-uaen-sentinel-hub').EasmAsset_CL\r\n| extend Type = iff(Type == \"AzureDevOpsAuditing\", \"Azure DevOps\",\r\n                iff(Type == \"QualysHostDetectionV3_CL\", \"Qualys\",\r\n                iff(Type == \"Informatica_CL\", \"Informatica\",\r\n                iff(Type == \"Palantir_CL\", \"Palantir v2\",\r\n                iff(Type == \"Palantirv3_CL\", \"Palantir v3\",\r\n                iff(Type == \"EasmAsset_CL\", \"Defender EASM\",  \r\n                iff(Type == \"GitHubAuditLogsV2_CL\", \"GitHub Enterprise\",\r\n                iff(Type == \"Auth0_CL\", \"Auth0\",\r\n                iff(Type == \"juniper_CL\", \"Juniper Mist\", \"UNKNOWN\")))))))))\r\n| extend Organization = iff(isnotempty(Org), Org, \r\n                        iff(isnotempty(WorkspaceName_s), WorkspaceName_s,\r\n                        iff(isnotempty(orgId), orgId, \r\n                        iff(isnotempty(ScopeDisplayName), ScopeDisplayName,\r\n                        iff(isnotempty(tostring(parse_json(data).tenant_name)), tostring(parse_json(data).tenant_name),\r\n                        iff(isnotempty(CustomerName), CustomerName,\r\n                        iff(isnotempty(TenantId), TenantId, \"UNKNOWN\")))))))\r\n| summarize EventCount = count(), GBytes = round(sum(_BilledSize)/(1024*1024*1024),2) by Type, Organization\r\n| order by EventCount",
        "size": 2,
        "showAnalytics": true,
        "title": "Onboarded SaaS Resources",
        "timeContextFromParameter": "TimeRange",
        "showRefreshButton": true,
        "showExportToExcel": true,
